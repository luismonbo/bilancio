# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Test & coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json

# ── Secrets & local config ────────────────────────────────────────────────────
.env
# .env.example is intentionally NOT ignored — it documents required variables

# ── Databases (local dev) ─────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── Uploads (local file storage) ─────────────────────────────────────────────
uploads/

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Personal dev scripts (local tooling, not for the repo) ───────────────────
scripts/

# ── Claude Code project instructions (personal workflow, not for public repos) ─
CLAUDE.md

# ── Local docs (personal notes, ADRs, briefs — not for public repos) ──────────
docs/

# ── Bank statement fixtures (may contain real financial data) ─────────────────
tests/fixtures/*.xlsx
tests/fixtures/*.csv
tests/fixtures/*.pdf
# tests/fixtures/.gitkeep is intentionally NOT ignored

# ── Alembic ───────────────────────────────────────────────────────────────────
# Autogenerated migration scripts that contain real data are not committed.
# Only checked-in migrations in alembic/versions/ are tracked.

# ── Docker ────────────────────────────────────────────────────────────────────
# docker-compose.override.yml is local — use docker-compose.yml for the base config
docker-compose.override.yml
