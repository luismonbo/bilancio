# Copy to .env for local development. Never commit .env.
# Production secrets live in Azure Key Vault.

# --- Required ---
# Use sqlite+aiosqlite:///./bilancio.db for local SQLite dev
# Use postgresql+asyncpg://user:pass@host:5432/bilancio for Postgres
DATABASE_URL=sqlite+aiosqlite:///./bilancio.db

# --- LLM ---
LLM_BACKEND=ollama                          # ollama | azure_foundry
OLLAMA_URL=http://localhost:11434
LLM_MODEL=gemma4:e2b
# AZURE_FOUNDRY_ENDPOINT=                   # required when LLM_BACKEND=azure_foundry
# AZURE_FOUNDRY_API_KEY=                    # local dev only; Managed Identity in prod
LLM_CONFIDENCE_THRESHOLD=0.8

# --- File storage ---
FILE_STORAGE_BACKEND=local                  # local | azure_blob
LOCAL_FILE_DIR=./uploads

# --- Observability ---
# APPINSIGHTS_CONNECTION_STRING=            # empty = disabled locally

# --- Rate limiting ---
RATE_LIMIT=60/minute

# --- Debug ---
DEBUG=false